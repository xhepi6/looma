# Application
APP_SECRET_KEY=change-me-to-a-secure-random-string

# Ports for local development
API_PORT=8000
WEB_PORT=5173

# CORS (for production, set your domain)
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Users (seeded on first run)
SEED_USER_1_USERNAME=alice
SEED_USER_1_PASSWORD=password123
SEED_USER_2_USERNAME=bob
SEED_USER_2_PASSWORD=password123

# Discord notifications (optional)
DISCORD_WEBHOOK_URL=
REMINDER_ENABLED=false
